{
  "container_name": "mqtt-kuksa-feeder",
  "image": {
    "name": "ghcr.io/siemens/mqtt-kuksa-feeder:latest"
  },
  "host_config": {
    "network_mode": "host",
    "restart_policy": {
      "type": "unless-stopped"
    },
    "log_config": {
      "driver_config": {
        "type": "json-file",
        "max_files": 3,
        "max_size": "5M"
      }
    }
  },
  "config": {
    "env": [
      "MQTT_HOST=localhost",
      "MQTT_PORT=1883",
      "KUKSA_HOST=127.0.0.1",
      "KUKSA_PORT=55555"
    ]
  }
}
